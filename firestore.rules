rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin()    { return isSignedIn() && myRole() == 'admin'; }
    function isStaffOrAdmin() { return isSignedIn() && (myRole() == 'staff' || myRole() == 'admin'); }
    function isDirector()  { return isSignedIn() && myRole() == 'director'; }
    function isActive()    { return isSignedIn() && myRole() != 'pending' && myRole() != null; }

    // ---- 使用者角色 ----
    match /users/{uid} {
      // 任何已登入且非待設定者可以查詢單一使用者資料（供Email通知查詢收件人信箱用），但不能列出全部使用者
      allow get: if isActive();
      allow list: if isAdmin();
      // 使用者第一次登入時，前端會自動建立自己的文件（角色預設 pending）；
      // 主任也可以直接幫新同仁建立帳號資料並指定角色
      allow create: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid && request.resource.data.role == 'pending');
      // 角色變更只能由 admin 執行；但每個人可以自行記錄「新手導覽是否已看過」
      allow update: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onboardedRoles']));
      allow delete: if isAdmin();
    }

    // ---- Email 通知收件人設定 ----
    match /config/notifyEmails {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // ---- 支出類別設定 ----
    match /config/categories {
      allow read: if isActive();
      allow write: if isStaffOrAdmin();
    }

    // ---- 支出紀錄 ----
    match /expenses/{id} {
      allow read: if isActive();
      allow create: if isStaffOrAdmin();
      allow delete: if isStaffOrAdmin();

      // staff / admin 可以修改任何欄位
      // director 只能修改核示相關欄位（不能改金額、類別、摘要等原始登打內容）
      allow update: if isStaffOrAdmin() ||
        (isDirector() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'statusBy', 'statusAt', 'directorNotes', 'directorNote', 'directorNoteBy', 'directorNoteRole']));
    }
  }
}
